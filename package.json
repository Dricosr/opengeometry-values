{
  "name": "@dricosr/opengeometry-values",
  "version": "0.1.0-alpha.1",
  "description": "Structured engineering values with type, quantity, unit conversion, internal normalization and UI formatting for OpenGeometry.",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "check:customizations": "node ./scripts/check-customizations.mjs",
"test": "vitest run",
    "test:visual": "vitest run tests/visual",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "opengeometry",
    "units",
    "engineering",
    "values",
    "cad",
    "mathjs",
    "esm"
  ],
  "author": "Adriano Ribeiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dricosr/opengeometry-values.git"
  },
  "bugs": {
    "url": "https://github.com/Dricosr/opengeometry-values/issues"
  },
  "homepage": "https://github.com/Dricosr/opengeometry-values#readme",
  "dependencies": {
    "mathjs": "15.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
