{
  "name": "@dricosr/iforge-edp-values",
  "version": "0.4.5",
  "description": "Structured engineering values with type, quantity, unit conversion, internal normalization and UI formatting for iForge EDP.",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "browser": "./dist/index.iife.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "prepublishOnly": "npm test && npm run build",
    "test": "vitest run",
    "test:visual": "vitest run tests/visual",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "iforge-edp",
    "units",
    "engineering",
    "values",
    "cad",
    "mathjs",
    "esm"
  ],
  "author": "Adriano Ribeiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dricosr/iforge-edp-values.git"
  },
  "bugs": {
    "url": "https://github.com/Dricosr/iforge-edp-values/issues"
  },
  "homepage": "https://github.com/Dricosr/iforge-edp-values#readme",
  "dependencies": {
    "mathjs": "15.2.0"
  },
  "peerDependencies": {
    "mathjs": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "mathjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "rollup": "4.60.2",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
