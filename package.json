{
  "name": "opengeometry-values",
  "version": "0.1.0-alpha.1",
  "description": "Structured engineering values with type, quantity, unit conversion, internal normalization and UI formatting for OpenGeometry.",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "check:customizations": "node ./scripts/check-customizations.mjs",
    "demo:dev": "nodemon --watch demo --watch src --ext mjs,html,css ./demo/server.mjs",
    "demo:start": "node ./demo/server.mjs",
    "test": "vitest run",
    "test:visual": "vitest run tests/visual",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "opengeometry",
    "units",
    "engineering",
    "values",
    "cad",
    "mathjs",
    "esm"
  ],
  "author": "Adriano Ribeiro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opengeometry/opengeometry-values.git"
  },
  "bugs": {
    "url": "https://github.com/opengeometry/opengeometry-values/issues"
  },
  "homepage": "https://github.com/opengeometry/opengeometry-values#readme",
  "dependencies": {
    "express": "5.2.1",
    "mathjs": "15.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "nodemon": "3.1.14",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
